    "@dnd-kit/sortable": "^7.0.2",
    "@dnd-kit/utilities": "^3.2.2",
    "zod": "3.23.8",
    "sonner": "1.5.0",
    "lucide-react": "0.400.0"
  },
  "devDependencies": {
    "vite": "5.4.0",
    "@vitejs/plugin-react": "4.3.1",
