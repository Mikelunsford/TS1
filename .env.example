# Root-level env. The SPA env (`apps/web/.env.local`) is separate and
# requires the `VITE_` prefix to reach the browser.
#
# These are the secrets your CI workflows and local Supabase CLI need.

# Supabase project (from environment.md)
SUPABASE_PROJECT_REF=ozvanymuzaqbexchuoxz
SUPABASE_URL=https://ozvanymuzaqbexchuoxz.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.replace-me
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.replace-me
SUPABASE_DB_PASSWORD=replace-me

# Pull from https://supabase.com/dashboard/project/<ref>/settings/api
# JWT Secret (raw, not the JWT token; used by Edge Functions to verify auth).
SUPABASE_JWT_SECRET=replace-me-with-jwt-secret-from-supabase-dashboard

# Supabase CLI access (pulled from https://supabase.com/dashboard/account/tokens)
SUPABASE_ACCESS_TOKEN=replace-me

# Vercel (set after `vercel link` populates .vercel/project.json)
VERCEL_TOKEN=replace-me
VERCEL_ORG_ID=replace-me
VERCEL_PROJECT_ID=replace-me

# Whitelabel
APP_NAME=Team1
BASE_DOMAIN=team1.app
DEFAULT_TENANT_BRAND=team1

# Allowed CORS origins for Edge Functions (comma-separated).
# Local dev includes http://localhost:5173 unconditionally.
ALLOWED_ORIGINS=https://team1.app,https://*.team1.app
